# PostgreSQL Configuration
POSTGRES_USER=aerys           # Database username
POSTGRES_PASSWORD=            # Database password (generate a strong one)

# n8n Configuration
N8N_ENCRYPTION_KEY=           # Encryption key for n8n credentials (generate with: openssl rand -hex 32)

# Webhook / Editor URLs (set to your domain or localhost)
WEBHOOK_URL=https://your-domain.example.com/
N8N_EDITOR_BASE_URL=https://your-domain.example.com

# Timezone
GENERIC_TIMEZONE=America/New_York
